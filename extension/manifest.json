{
  "manifest_version": 3,
  "name": "갈피 — 읽기 전 배경지식 브리핑",
  "version": "0.1.1",
  "description": "기사가 전제하는 배경지식(개념·이전 사건)을 읽기 전에 채워주고, 본문에 하이라이트합니다. 광고 없는 리더 뷰 포함.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "갈피 잡기 — 읽기 전 브리핑",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": { "default_path": "sidepanel.html" }
}
